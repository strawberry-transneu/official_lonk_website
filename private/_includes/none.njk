  <meta name="keywords" content="webcomic">
  <meta charset="UTF-8" />
  <title>{{title}}</title>
  		<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" href="{{ '/' | url }}imgs/favicon.ico">
  
      <link rel="stylesheet" type="text/css" href="{{ '/' | url }}fonts/style.css"/>
  
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
	<style type="text/tailwindcss">
	@theme {
  --animate-wiggle: wiggle 7s ease-in-out infinite;  
  @keyframes wiggle 
  { 
    10%, 90% {
    transform: translate3d(-1px, 0, 0);
  }
  
  20%, 80% {
    transform: translate3d(2px, 0, 0);
  }

  30%, 50%, 70% {
    transform: translate3d(-3px, 0, 0);
  }

  40%, 60% {
    transform: translate3d(3px, 0, 0);
  }
  }
  
	
	--color-fortext: #380404;
	--color-buttontext: white;
	
	--color-misha: #022270;
	--color-zaria: #4a9333;
	--color-acryl: #b99111;
	--color-dima: #a50505;

	--background-image-home: url('{{ '/' | url }}./imgs/bg_checker.png');
	--background-image-cardboard: url('{{ '/' | url }}./imgs/cardboard.png');
	--background-image-paper: url('{{ '/' | url }}./imgs/seamless.png');
	--background-image-darkpaper: url('{{ '/' | url }}./imgs/dark_seamless.png');
	--color-dark: #59423F;
	--color-dark-force: #59423F;
	--color-light: #E2D7C7;
	--color-light-force: #E2D7C7;
	--color-highlight: oklch(89.2% 0.058 10.001);
	--background-image-paper-force: url('{{ '/' | url }}./imgs/seamless.png');

	--font-loverboy: "Loverboy", "Courier New", Courier, monospace; 

	--font-mau: "Mau", "Courier New", Courier, monospace; 

	--font-sans: "Comic Sans MS", "Comic Sans", cursive, sans-serif;


	--font-cmu: "CMU Typewriter Text Regular", "Courier New", Courier, monospace; 
	--font-block: "block", "Courier New", Courier, monospace;
	--font-spike: "spike", "Courier New", Courier, monospace;
	--font-punk: "punk_01", 'block', "Courier New", Courier, monospace;
		--font-punk2: "punk_03", "Courier New", Courier, monospace;
		--font-punk3: "punk_05", "Courier New", Courier, monospace;
		--font-punk4: "punk_07", "Courier New", Courier, monospace;

	}
	
	
  [data-theme='default_dark'] {
	--background-image-home: url('{{ '/' | url }}./imgs/dark_bg_checker.png');
	--color-dark: #59423F;
  }	
				
  [data-theme-primary='dark']{
   --color-dark: white;
   --color-light: #242020;
   --color-fortext: #E1D7CC;
   --color-buttontext: #242020;
   --color-highlight: black;

   --background-image-cardboard: url('{{ '/' | url }}./imgs/dark_cardboard.png');
   --background-image-darkpaper: url('{{ '/' | url }}./imgs/dark_dark_seamless.png');
   --background-image-paper: url('{{ '/' | url }}./imgs/dark_mode_seamless.png');
  }
  
  [data-theme='zaria'] {
	--background-image-home: url('{{ '/' | url }}./imgs/zaria_bg_checker.png');
	--color-dark: #59423F;
  }	
  
   [data-theme='zaria_dark'] {
	--background-image-home: url('{{ '/' | url }}./imgs/zaria_bg_checker_dark.png');
	--color-dark: #59423F;
  }	
  
  [data-theme='misha'] {
	--background-image-home: url('{{ '/' | url }}./imgs/misha_bg_checker.png');
	--color-dark: #59423F;
  }	
  
   [data-theme='misha_dark'] {
	--background-image-home: url('{{ '/' | url }}./imgs/misha_bg_checker_dark.png');
	--color-dark: #59423F;
  }	

  [data-theme='acryl'] {
	--background-image-home: url('{{ '/' | url }}./imgs/acryl_bg_checker.png');
	--color-dark: #59423F;
  }	
  
  [data-theme='acryl_dark'] {
	--background-image-home: url('{{ '/' | url }}./imgs/acryl_bg_checker_dark.png');
	--color-dark: #59423F;
  }	  

  [data-theme='dima'] {
	--background-image-home: url('{{ '/' | url }}./imgs/dima_bg_checker.png');
	--color-dark: #59423F;
  }	
  
  
  [data-theme='dima_dark'] {
	--background-image-home: url('{{ '/' | url }}./imgs/dima_bg_checker_dark.png');
	--color-dark: #59423F;
  }	
  
  
  
  .lonkin{
  @apply text-rose-200 decoration-2 underline font-black text-[1.1em];
  }
  
  .mirror{
  display:inline-block; transform: scale(-1, 1);
  }
  
  .flip{
  display:inline-block; transform: scale(1, -1);
  }
  
  .text-outline{	
  -webkit-text-stroke: 1px black;
  text-shadow: 4px 4px 0px black;
  }
  
  .text-outline-5{	
  -webkit-text-stroke: 0.7px black;
  text-shadow: 4px 4px 0px black;
  }
  
	a {
	@apply underline decoration-[3px];
	}

  
	blockquote {
	@apply bg-cardboard bg-size-[100%_100%] text-white py-2 inline-block -skew-x-8;
	}
		
	
	body {
	@apply bg-size-[145px];
	}
	
	li{
	list-style-type: "\2606";
	margin-left: 1.20em;
	padding-inline-start: 0.5em;
	}

	.flex-center{
	@apply flex justify-center items-center;
	}
  
	@layer base {  
	
	h1 {    
	@apply text-[1.35em] md:text-[1.65em] font-punk;
	font-weight: 400;}  
	
	h2 {    
	text-size: 1.25em; 
	font-weight: bold;}
	
	h3 {    
	text-size: 1.20em; 
	margin-left: 1em;
	font-weight: bold;}
	
	u {
	@apply decoration-2;
	}
		
	.rainbow-order > *:nth-child(1n){
	@apply bg-rose-300;
	}
	
	.rainbow-order > *:nth-child(2n){
		@apply bg-orange-200;

	}
		.rainbow-order > *:nth-child(3n){
		@apply bg-cyan-200;

	}
	
	.rainbow-order > *:nth-child(4n){
		@apply bg-blue-200;

	}
	
	.dima-border{
	border-image-slice: 4% 3% 5% 2%;
border-image-width: 0.3em 0.3em 0.3em 0.3em;
border-image-outset: 0px 0px 0px 0px;
border-image-repeat: stretch stretch;
border-image-source: url("{{ '/' | url}}imgs/border_dima.png");
border-style: solid;
	}
	
	
	.acryl-border{
	border-image-slice: 4% 3% 5% 2%;
border-image-width: 0.3em 0.3em 0.3em 0.3em;
border-image-outset: 0px 0px 0px 0px;
border-image-repeat: stretch stretch;
border-image-source: url("{{ '/' | url}}imgs/border_acryl.png");
border-style: solid;
	}
	
		.rainbow-order-hover > *:nth-child(1n of :not(.hidden)){
	@apply bg-rose-300 hover:bg-rose-400;
	}
	
	.rainbow-order-hover > *:nth-child(2n of :not(.hidden)){
		@apply bg-orange-200 hover:bg-orange-300;

	}
		.rainbow-order-hover > *:nth-child(3n of :not(.hidden)){
		@apply bg-cyan-200 hover:bg-cyan-300;

	}
	
	.rainbow-order-hover > *:nth-child(4n of :not(.hidden)){
		@apply bg-blue-300 hover:bg-blue-400;

	}
	
	
	.button:not(.button-none), button:not(.button-none) {
	border: solid 4px black;
	@apply px-[0.3em] py-[0.5em] md:px-[0.4em] md:py-[0.2em] hover:bg-paper font-bold text-white bg-dark bg-darkpaper bg-size-[120px] text-buttontext;
	box-shadow: 3px 3px 0px 0px rgba(40,0,0,0.7);
	
	margin: 2px;

	text-decoration: none !important;
	}
	
	
	
  
	}
	
	.jolly-text{
--color1: #1FD537;
--color2: #E40010;
background: repeating-linear-gradient(
45deg,
var(--color1),
var(--color1) 30px,
var(--color2) 30px,
var(--color2) 60px
);
background-clip: text;
color: transparent;
-webkit-background-clip: text;
animation: 40s linear 0s infinite move;
}

@keyframes move {
from {
background-position: 0px;
}
to {
background-position: 1000px;
}
}
	
	</style>
	
	
<style>

 @keyframes squish {
  0%   {
    transform: scaleY(100%);

	}
  100%  {
    transform: scaleY(99%) translateY(1%) scaleX(101%);

	}
}

.squishing {
  animation-name: squish;
  animation-iteration-count: 2;
  animation-duration: 0.1s;
  animation-direction: alternate;
} 
</style>


</head>


<body class='addtransitions font-cmu text-[1.15em] md:text-[1.25em] bg-home text-fortext min-w-0'>
