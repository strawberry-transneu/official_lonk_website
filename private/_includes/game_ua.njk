// CHOICES ENGINE 

function generateChoices(current_choices){


const choicebox = document.getElementById('choices_list');
choicebox.innerHTML=''; // clearing the box of all options

for (const choice of current_choices) {
  const newButton = document.createElement("button");  
  let new_act='hideAllFast(); currDialogueCount=0; currDialogueBranch='+choice.act+'; currDialogueBranchName="'+ choice.act +'"; next_dialogue();'
  newButton.setAttribute("onClick", new_act);
  newButton.innerHTML=choice.title;
  choicebox.appendChild(newButton);
  
  let temporary = (choice.act).toString();
  
  
  if (choice.unlockable){
  
  let temporary_2=temporary+'_unlocked';
  if( (localStorage.getItem(temporary_2))=='true'){
  newButton.classList.remove('hidden');
  newButton.classList.add('block');
  }else{
  newButton.classList.add('hidden');
  newButton.classList.remove('block');
  }
  }
  
  
  console.log(temporary+' < is temporary');
  
  console.log(localStorage.getItem(temporary) + ' < is the data we get from temporary')
  if( (localStorage.getItem(temporary))=="true" ){
  newButton.classList.add('hidden');
  newButton.classList.remove('block');

  }
  
  
  }
  
  
  
}


