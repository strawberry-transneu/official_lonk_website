}

function getCookie(name) {
    return localStorage.getItem(name);  // get value
}


function setTheme(a){
if(a==='default'){
document.getElementsByTagName("HTML")[0].setAttribute("data-theme", null); 
setCookie('theme', null);
}else{
document.getElementsByTagName("HTML")[0].setAttribute("data-theme", a); 
setCookie('theme', a);
}
}

function setThemePrimary(a){

if(a==='default'){
document.getElementsByTagName("HTML")[0].setAttribute("data-theme-primary", null); 
setCookie('primary-theme', null);
}else{
document.getElementsByTagName("HTML")[0].setAttribute("data-theme-primary", a); 
setCookie('primary-theme', a);
}

}


</script>


