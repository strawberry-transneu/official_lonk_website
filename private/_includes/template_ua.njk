	.jolly-text{
--color1: #1FD537;
--color2: #E40010;
background: repeating-linear-gradient(
45deg,
var(--color1),
var(--color1) 30px,
var(--color2) 30px,
var(--color2) 60px
);
background-clip: text;
color: transparent;
-webkit-background-clip: text;
animation: 40s linear 0s infinite move;
}

@keyframes move {
from {
background-position: 0px;
}
to {
background-position: 1000px;
}
