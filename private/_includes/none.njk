<div id='normal' class='min-w-0 *:min-w-0 w-[100%] md:w-[95%] lg:w-[85%]'>

<header class='flex flex-row gap-1 m-2 justify-between items-center'>
</header>

<main class='flex m-4 justify-center items-center flex-col min-w-0 bg-light'>
{% block inside %}

{{ content | safe }}

{% endblock %}
</main>

</div>

</div>
