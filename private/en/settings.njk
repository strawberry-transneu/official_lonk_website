<h2>🔒 SPOILERS-FREE MODE:</h2> <u id='s_status'>currently ON</u> <button onclick='s_mode();'>CHANGE ?</button>

<script>

const nameinput=document.getElementById('namehere');

function changeName(){
localStorage.setItem('username', nameinput.value);
alert('name was changed! try to reload the page');
}

const s_state=localStorage.getItem('spoiler_state');
const s_show_text=document.getElementById('s_status');
if (s_state==='true'){
s_show_text.innerHTML='currently ON ✅';
}else if (s_state==='false'){
s_show_text.innerHTML='currently OFF ❌';
}

function s_mode(){

if (s_state==='true'){
 localStorage.setItem("spoiler_state", 'false');
 alert('state was changed! try to reload the page');

}else if (s_state==='false'){
 localStorage.setItem("spoiler_state", 'true');
 alert('state was changed! try to reload the page');
}

}

</script>


