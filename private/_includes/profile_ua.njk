<script>
function pfpPick(x, custom){
let y;
if (!custom){
y = "{{ '/' | url }}imgs/pfps/"+x;
}else{
y = x;
}

const pfpArray = document.querySelectorAll(".pfp"); 
for (let i = 0; i < pfpArray.length; i++) {
pfpArray[i].src=y;
}

console.log(y);
localStorage.setItem("pfp", y);
}


</script>



