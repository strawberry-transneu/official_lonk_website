}); 


function hideAllFast(){

$("#choices_list").hide();
$("#d_thought").hide();
$("#d_text").hide();
$("#a_text").hide();

}

function hideAll(){

$("#choices_list").fadeOut(500);
$("#d_thought").fadeOut(500);
$("#d_text").fadeOut(500);
$("#a_text").fadeOut(500);

}

// nextAction

let currDialogueBranch=start_dialogue;
let currDialogueBranchName="start_dialogue";
let currDialogueCount=0;

function next_dialogue(){
if (currDialogueCount < currDialogueBranch.length){
text_Engine(currDialogueCount);

currDialogueCount+=1;
}

}


// TEXT ENGINE HELLO BBG!


function text_Engine(key){
			let line = currDialogueBranch[key];
			
			// DETERMINES WHO SPEAKS
			
			if (line.per == 'dt') {
					$("#d_thought").fadeIn(500);
					$("#d_thought").html('('+line.text+')');
			}else if(line.per == 'd'){
					$("#d_text").fadeIn(500);
					if (isMobile()) {
					$("#d_text").html('ДІМА: '+line.text);					
					}else{
					$("#d_text").html(line.text);
					}

			}else if(line.per == 'a'){
					$("#a_text").fadeIn(500);
					if (isMobile()) {
					$("#a_text").html('АКРИЛ: '+line.text);					
					}else{
					$("#a_text").html(line.text);
					}					
			}
			
			
			// CHECKS ADDITIONAL SETTINGS
			
			
				if (line.hide) { // this gotta be an array btw
					for (var i in line.hide) {
						console.log(line.hide[i]);
						$(line.hide[i]).stop();
						$(line.hide[i]).fadeOut(500);
					}
				}
				
				
				if (line.d_exp) { 
				
				//					$("#d_exp").addClass('squishing');

					$("#d_exp_new").fadeOut(0);
					document.getElementById('d_exp_new').style.backgroundImage="url( {{'/' | url}}" + "imgs/comics_1_game/d_" + line.d_exp +".png " + ")";
					
					$("#d_exp_new").fadeIn(105);

					setTimeout(
					function() 
					{
						document.getElementById('d_exp').style.backgroundImage="url( {{'/' | url}}" + "imgs/comics_1_game/d_" + line.d_exp +".png " + ")";

				// 					$("#d_exp").removeClass('squishing');
					}, 80); 
				}
				
				if (line.a_exp) { 
					$("#d_exp_new").fadeOut(0);
					document.getElementById('a_exp_new').style.backgroundImage="url( {{'/' | url}}" + "imgs/comics_1_game/a_" + line.a_exp +".png " + ")";
					
					$("#a_exp_new").fadeIn(105);

					setTimeout(
					function() 
					{
						document.getElementById('a_exp').style.backgroundImage="url( {{'/' | url}}" + "imgs/comics_1_game/a_" + line.a_exp +".png " + ")";

					}, 80);
					  
				}
		
		
			if (line.unlock) {
				let temporaryy = (line.unlock.toString()+'_unlocked');
				localStorage.setItem(temporaryy, true);
			}
			
			if (line.choices) {
					$("#choices_list").fadeIn(2000);
					generateChoices(line.choices);
			}
			
			
			if (line.saveCookie) {
				let temporaryy = (line.saveCookie.toString());
				localStorage.setItem(temporaryy, true);
			}
			
			if (line.achDisplay){
					showNewAchievement(line.achDisplay);
			}
			
			
			if (line.musicPause){
			pauseAudio();
			}
			
						
			if (line.musicPlay){
			playAudio(line.musicPlay)			
}
			
			if (line.done) {
			window.location.href = "./31.html";
			}
			
			
			if (currDialogueCount==0) {
			localStorage.setItem(currDialogueBranchName, false);
			}
			
			if (currDialogueCount>0) {
			localStorage.setItem(currDialogueBranchName, true);
			}
			
}
