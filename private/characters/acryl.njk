<script>
function isOdd(n) {
   return Math.abs(n % 2) == 1;
}

let musicArray = ["ротор'молла - восьмий колір", "the scary school - i want to kiss you", "marina and the brilliants - are you satisfied",  "marina and the brilliants - homewrecker", "veronicas the musical - the me inside of me", "veronicas the musical - meant to be yours", "veronicas the musical - dead girl walking (reprise)", "marina and the brilliants - are you satisfied", "gven stephanie - bubble pop electric", "marina and the brilliants - electra heart", "lovelythegroup - don’t worry, you will", "marina and the brilliants - how to be a heartbreaker", "king - good old-fashioned lover boy", 'lavril avinge - sk8er boi', 'lavril avinge - girlfriend', 'hallows - scrawny', 'deco*72 feat. matsune hiku - ghost rule | ゴーストルール ', 'deco*72 feat. matsune hiku - android girl | アンドロイドガール ', "deco*72 feat. matsune hiku - liar's dance | ライアーダンス", 'nakaria feat. gummi - KING ', "ротор'молла - восьмий колір", ];

/* needs 21 songs, not 20 due to math shenanigans, */

let musicArray2 = ["make out sunday - hope less romantics", "your chemical romance - cemetery", "your chemical romance - na na na",  "your chemical romance - to the end", "kotchi no Sugō - hai yorokonde | はいよろこんで", "old friend - HEADCASE", "AGR - BANG!", "paty kerry - i kissed a girl", "aria ena - it took me by surprise ", "stack jauber - baby hotline",  "your chemical romance - i'm not okay (i promise)", "kikio - aishite aishite aishite | 愛して愛して愛して", "king - good old-fashioned lover boy", 'lavril avinge - sk8er boi', 'lavril avinge - girlfriend', 'deco*72 feat. matsune hiku - hibana | ヒバナ ', 'deco*72 feat. matsune hiku - ghost rule | ゴーストルール ', 'deco*72 feat. matsune hiku - android girl | アンドロイドガール ', "deco*72 feat. matsune hiku - liar's dance | ライアーダンス", 'nakaria feat. gummi - KING ', "make out sunday - hope less romantics", ];

const music= document.getElementById("music");
const music_hold= document.getElementById("music_hold");

function round3(x)
{
    return Math.ceil(x / 3) * 3;
}


function update(){

let d = new Date(); 

let day = d.getDay();  // SUNDAY = 0 ; MONDAY = 1; SATURDAY = 6
let h = d.getHours();
let m = d.getUTCMinutes();


if (isOdd(h)){

let curSong=musicArray[ round3(m)/3 ];
music_hold.innerHTML='🎵 currently listening to';
music.innerHTML=curSong;

}else{

let curSong=musicArray2[ round3(m)/3 ];
music_hold.innerHTML='🎵 currently listening to';
music.innerHTML=curSong;

}


if( (day=='5' || day=='6' ) && (h>17 && h<23) ){   // GONE ON SATURDAY AND FRIDAY NIGHTS FROM 18 TO 22
music_hold.innerHTML='busy; not listening to anything right now.';
music.innerHTML='';
}

if( (h>3 && m>11) && (h<7 && m>02)){  // FROM 3.11 TO 7.02 IS ASLEEPY
music_hold.innerHTML='asleep; not listening to anything right now.';
music.innerHTML='';
}

}


const hebox= document.getElementById("he");
const shebox= document.getElementById("she");

function updatePronouns(){
let d = new Date(); 

let ddate = d.getDate();
let h = d.getUTCHours();
let month = d.getUTCMonth();
let m = d.getUTCMinutes();

if (!isOdd(month+1)){ //for odd months

let heArray=[1,2,3,4,5,7,8,9,11,15,16,19,20,23,24,25,26,27,28,30,31];
let sheArray=[1,3,4,5,7,12,13,14,16,19,20,23,30];


if(heArray.includes(ddate)){
hebox.innerHTML='/he';
}if(sheArray.includes(ddate)){
shebox.innerHTML='/she';
}

}else{             //for even months

let heArray=[1,2,3,4,5,7,8,9,14,15,17,18,19,20,23,24,25,26,27,28,30,31];
let sheArray=[4,5,8,12,14,16,19,20,22,24,29,31];

if(heArray.includes(ddate)){
hebox.innerHTML='/he';
}if(sheArray.includes(ddate)){
shebox.innerHTML='/she';
}

}



}

// LOAD PAGE:

addEventListener("DOMContentLoaded", (event) => { 
update();

setInterval(function() {
update();
}, 60*1000); //EVERY MINUTE CHECKS SONGS! :3


