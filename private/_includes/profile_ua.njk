<script>

function flag(layer, x){

if (x==0||x=="none"){

$( "#pfp_layer_"+layer ).css("background-image", "linear-gradient(to right, rgba(255,0,0,0), rgba(255,0,0,0))");


localStorage.removeItem('pfp_layer_'+layer);
}

else{

console.log(x);
if (typeof x !== 'object'){

if (x.startsWith("http")){
$( "#pfp_layer_"+layer ).css("background-image", "url(" + x + ")");
localStorage.setItem('pfp_layer_'+layer, "url(" + x + ")");
}else{
$( "#pfp_layer_"+layer ).css("background-image", x);
localStorage.setItem('pfp_layer_'+layer, x);
}
console.log('works');


}else{
$( "#pfp_layer_"+layer ).css("background-image", x.style.backgroundImage);
localStorage.setItem('pfp_layer_'+layer, x.style.backgroundImage);

}

}



}

</script>

