<script>

function isMobile() {
  const minWidth = 768; // Minimum width for desktop devices
  return window.innerWidth < minWidth || screen.width < minWidth;
}

if (isMobile()) {
  document.getElementById('choices_list').remove();
   document.getElementById('d_text').remove();
  document.getElementById('a_text').remove();
    document.getElementById('d_text_mobile').id='d_text';
  document.getElementById('a_text_mobile').id='a_text';

  document.getElementById('choices_list_mobile').id='choices_list';
} else {
  document.getElementById('choices_list_mobile').remove();
   document.getElementById('d_text_mobile').remove();
  document.getElementById('a_text_mobile').remove();

}

// MUSIC SECTION
var musicc = document.getElementById("music"); 

function playAudio(iddd) {
  // "mondayhopes_oj_on_the_table.mp3"
  musicc.src="{{'/'|url}}sounds/" + iddd;  
  musicc.volume=0;
  musicc.play(); 
  $('#music').animate({volume: 0.065}, 1000);
} 

function pauseAudio() { 
 $('#music').animate({volume: 0}, 1000);
					setTimeout(
					function() 
					{
   musicc.pause(); 

					}, 1010);

} 

